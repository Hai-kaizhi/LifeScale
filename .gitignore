# ============================================================================
# LifeScale 开源仓库 .gitignore
# ----------------------------------------------------------------------------
# 仓库根 = lifescale-open/（纯本地应用，无后端 / 无服务端）。
#
# 安全红线（无论是否在此列出，都绝不入库）：
#   - 签名密钥、SSL 证书（.keystore / .p12 / .pem / .key / .jks）
#   - 打包产物（APK / EXE / MSI）—— 输出到 dist/release/，已被忽略
#   - 用户运行时数据（本地 SQLite / Vault 文件）
# ============================================================================

# ---- Environment（环境变量，永不入库）----
.env
.env.local
.env.*.local

# ---- Logs（日志）----
*.log
logs/

# ---- OS and editors ----
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ---- AI 协作本地配置（私有，不入库）----
.claude/
CLAUDE.md

# ---- Node / pnpm / Vite（桌面端）----
node_modules/
dist/
.vite/
.turbo/
pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Tauri / Rust（桌面端）----
target/
**/src-tauri/target/
**/src-tauri/gen/
desktop/src-tauri/WixTools/

# ---- Flutter / Dart（移动端构建产物）----
mobile/build/
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
mobile/android/.gradle/
mobile/android/.kotlin/
mobile/android/captures/
mobile/android/local.properties
mobile/android/key.properties        # 签名配置，绝不入库
mobile/*.keystore
mobile/*.jks

# ---- 打包产物（APK/EXE/MSI 由打包脚本输出到 dist/release/，已被 dist/ 忽略）----
dist/release/

# ---- 备份与数据导出（绝不入库）----
backup/
*.dump
*.sql.gz
*.sql.bz2

# ---- 临时/调试垃圾文件 ----
.tmp_*
**/nul                                   # Windows 误重定向产生的伪文件

# ---- 本地签名与密钥 ----
*.p12
*.pfx
secrets/
*.pem
*.crt
*.key
