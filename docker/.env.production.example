# ============================================================================
# LifeScale 生产环境变量模板
# ----------------------------------------------------------------------------
# 用途：docker-compose.full.yml 的 --env-file。本地验证 + 服务器部署通用。
#
# ⚠️ 这是【模板】。部署前必须复制为 .env 并替换为强随机真实值：
#     cp .env.production.example .env    （然后编辑 .env）
#     .env 已被 .gitignore 忽略，不会提交，含敏感凭据。
#
# 强随机值生成命令（Linux/Mac/Git Bash / 服务器）：
#     openssl rand -base64 48    # 生成 48 字节 base64，用于 JWT secret
#     openssl rand -base64 24    # 生成 24 字节 base64，用于 PG/Redis 密码
# ============================================================================

# ============ 数据库 ============
POSTGRES_DB=lifescale
POSTGRES_USER=lifescale
POSTGRES_PASSWORD=ChangeMe_PG_StrongP@ssw0rd_2026      # 必改：openssl rand -base64 24

# ============ Redis ============
REDIS_PASSWORD=ChangeMe_Redis_StrongP@ssw0rd_2026      # 必改：openssl rand -base64 24

# ============ JWT（HS256，需 ≥32 字节；prod 缺失或弱默认会 fail-fast）===========
LIFESCALE_JWT_SECRET=ChangeMe_JWT openssl rand -base64 48 至少32字节   # 必改：openssl rand -base64 48
LIFESCALE_JWT_TTL_HOURS=24

# ============ Bootstrap 管理员（首次启动创建；prod 弱密码会 fail-fast）===========
# 密码必须 ≥8 位且含字母+数字，否则后端拒绝启动
LIFESCALE_BOOTSTRAP_USERNAME=admin
LIFESCALE_BOOTSTRAP_PASSWORD=ChangeMe_Bootstrap_StrongP@ssw0rd_2026  # 必改：自定义强密码（≥8位含字母数字），登录后立即在客户端修改

# ============ 邀请码注册（prod 默认开启；登录后由 admin 生成邀请码）===========
LIFESCALE_INVITE_CODE_ENABLED=true
LIFESCALE_INVITE_CODE_TTL_DAYS=7

# ============ 限流（prod 默认开启）===========
LIFESCALE_RATE_LIMIT_ENABLED=true

# ============ 腾讯云 COS（附件存储；留空则回退磁盘 CAS，不影响启动）===========
# 生产建议配置（图片附件走 COS，省服务器磁盘 + 带宽）
LIFESCALE_COS_SECRET_ID=
LIFESCALE_COS_SECRET_KEY=
LIFESCALE_COS_REGION=ap-guangzhou
LIFESCALE_COS_BUCKET=
LIFESCALE_COS_CDN_DOMAIN=
LIFESCALE_COS_PREFIX=att

# ============ 服务器 Markdown 镜像根目录（可选，留空则不启用服务器落盘，仅用 CAS）===========
LIFESCALE_SERVER_MD_ROOT=

# ============================================================================
# 域名说明（不在 .env，在 nginx 配置里）
# ----------------------------------------------------------------------------
# 生产域名需要修改 nginx/conf.d/lifescale.conf 里的 server_name（所有 YOUR_DOMAIN.com）
# 部署时用 sed 替换：
#   sed -i 's/YOUR_DOMAIN.com/你的真实域名/g' nginx/conf.d/lifescale.conf
# 详见 nginx/DEPLOY.md
# ============================================================================
