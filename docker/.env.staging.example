# ============================================================================
# LifeScale staging 环境变量模板（上线前联调验收）
# ----------------------------------------------------------------------------
# 【唯一用途】docker-compose.staging.yml 的 .env，staging 独立密钥与配置。
# 【谁读取】docker-compose.staging.yml（需先 source 到 shell，见 08 文档 §9.1）。
# 【隔离原则】staging 与 prod 必须完全隔离：
#   - 不同的 PG/Redis/JWT/Bootstrap 密钥（不复用 prod 的）
#   - 不同的 COS prefix（staging/att vs prod 的 att）
#   - 独立数据卷（docker-compose.staging.yml 已用 -staging 后缀隔离）
# 【入库策略】本文件入库（占位值）；复制为 .env 后不入库。
#
# 使用：
#   cp .env.staging.example .env
#   vim .env    # 填 staging 独立强随机值
#
# 强随机值生成：
#   openssl rand -base64 48    # JWT secret
#   openssl rand -base64 24    # PG/Redis 密码
# ============================================================================

# ============ staging 端口（避开 prod 的 8080）============
# staging backend 对外暴露端口，默认 8081
STAGING_BACKEND_PORT=8081
# 绑定地址：0.0.0.0=对外可访问（需安全组放行），127.0.0.1=仅本机
STAGING_BIND_HOST=0.0.0.0

# ============ 数据库（staging 独立，不复用 prod 密码）============
POSTGRES_DB=lifescale
POSTGRES_USER=lifescale
POSTGRES_PASSWORD=ChangeMe_Staging_PG_StrongP@ssw0rd      # 必改：openssl rand -base64 24

# ============ Redis（staging 独立）============
REDIS_PASSWORD=ChangeMe_Staging_Redis_StrongP@ssw0rd      # 必改：openssl rand -base64 24

# ============ JWT（staging 独立强随机，与 prod 不同）============
LIFESCALE_JWT_SECRET=ChangeMe_Staging_JWT openssl rand -base64 48   # 必改
LIFESCALE_JWT_TTL_HOURS=24

# ============ Bootstrap 管理员（staging 独立账号）============
LIFESCALE_BOOTSTRAP_USERNAME=admin
LIFESCALE_BOOTSTRAP_PASSWORD=ChangeMe_Staging_Bootstrap_P@ss      # 必改：≥8位含字母数字

# ============ 邀请码（staging 可关闭，方便测试注册）============
LIFESCALE_INVITE_CODE_ENABLED=false
LIFESCALE_INVITE_CODE_TTL_DAYS=7

# ============ 限流 ============
LIFESCALE_RATE_LIMIT_ENABLED=true

# ============ 腾讯云 COS（staging 用独立 prefix，避免污染 prod 附件）============
# 可复用 prod 的 COS 子账号密钥，但 prefix 必须不同（staging/att）
LIFESCALE_COS_SECRET_ID=
LIFESCALE_COS_SECRET_KEY=
LIFESCALE_COS_REGION=ap-guangzhou
LIFESCALE_COS_BUCKET=
LIFESCALE_COS_CDN_DOMAIN=
LIFESCALE_COS_PREFIX=staging/att

# ============ 服务器 Markdown 镜像根目录（可选）============
LIFESCALE_SERVER_MD_ROOT=

# ============================================================================
# 部署提醒
# ----------------------------------------------------------------------------
# 1. staging 与 prod 在不同目录：/opt/LifeScale-staging vs /opt/LifeScale
# 2. 安全组需放行 staging 端口（默认 8081）
# 3. staging 不启 nginx，直接 IP:8081 访问（验收用，不对外公开）
# 4. 验收完成后，staging 数据可随时清（down -v），不影响 prod
# ============================================================================
