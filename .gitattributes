# LifeScale code 仓库跨平台换行符与二进制规范
# 仓库根 = code/，依据《项目重构与规范化指南.md》阶段 1.2

# 默认：文本文件自动检测，统一为 LF
* text=auto eol=lf

# ---- 文本类型显式指定 ----
*.md       text eol=lf
*.java     text eol=lf
*.rs       text eol=lf
*.ts       text eol=lf
*.tsx      text eol=lf
*.js       text eol=lf
*.jsx      text eol=lf
*.json     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.xml      text eol=lf
*.sql      text eol=lf
*.dart     text eol=lf
*.kt       text eol=lf
*.kts      text eol=lf
*.gradle   text eol=lf
*.toml     text eol=lf
*.properties text eol=lf
*.ps1      text eol=lf
*.sh       text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf
*.editorconfig text eol=lf
.env.example   text eol=lf
.env.production.example text eol=lf

# Windows 批处理保留 CRLF（cmd 解析需要）
*.bat      text eol=crlf
*.cmd      text eol=crlf

# ---- 二进制文件（不做换行符转换）----
# 图片
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.webp     binary
*.ico      binary
*.icns     binary
# SVG 实质是文本，按文本处理
*.svg      text eol=lf
# 文档
*.pdf      binary
# 压缩包
*.zip      binary
*.gz       binary
*.bz2      binary
*.7z       binary
*.tar      binary
# 数据库导出
*.dump     binary
*.db       binary
*.sqlite   binary
# 签名与密钥
*.keystore binary
*.jks      binary
*.p12      binary
*.pfx      binary
# 客户端安装包
*.apk      binary
*.ipa      binary
*.aab      binary
*.exe      binary
*.msi      binary
*.dmg      binary
*.deb      binary
*.rpm      binary
*.AppImage binary
# 字体
*.ttf      binary
*.otf      binary
*.woff     binary
*.woff2    binary
