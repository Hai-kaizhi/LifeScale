# ============================================================================
# LifeScale 桌面端 Vite 配置模板
# ----------------------------------------------------------------------------
# 【唯一用途】桌面端前端 Vite 构建配置（API 地址 + mock 开关）。
# 【谁读取】Vite（vite.config.ts）经 import.meta.env.VITE_* 读取。
# 【不要混用】本文件只控制前端 Vite 变量，不含后端/数据库/JWT 配置。
# 【入库策略】本文件入库（默认值指向本地后端）；复制为 .env 后不入库。
#
# 使用：cp .env.example .env  （然后按需修改 .env）
# ============================================================================

# API 基地址。常见取值：
#   - 本地后端（start.bat 起的 mvn 后端）：http://localhost:8080/api
#   - 临时上线服务器（域名审核期间）：http://<服务器IP>:8080/api
#   - 正式域名（域名备齐后）：https://你的域名/api
VITE_API_BASE_URL=http://localhost:8080/api

# Mock 开关。true=前端用 mock 数据不请求后端；false=请求真实后端。
# 本地后端联调时设 false。
VITE_USE_MOCK=false
